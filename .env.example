APP_NAME=PIX-Fraud-RealTime
VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Database (TimescaleDB)
DATABASE_URL=postgresql://antifraude:antifraude@timescaledb:5432/antifraude
TIMESCALE_ENABLED=true

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_PIX_TOPIC=pix.transactions
KAFKA_ALERT_TOPIC=pix.alerts
KAFKA_GROUP_ID=pix-fraud-consumers

# Zero-Trust
PIX_API_KEY=change-this-api-key
ZERO_TRUST_ALLOWED_SERVICES=pix-gateway,sovereign-platform,ops-console
ZERO_TRUST_REQUIRE_SIGNATURE=false
ZERO_TRUST_HMAC_SECRET=change-hmac-secret

# SELS
SELS_SALT=change-sels-salt

# Alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_TO=

# Sovereign AI Security Platform
SOVEREIGN_PLATFORM_WEBHOOK=
SOVEREIGN_PLATFORM_TOKEN=
